# ── Task-Claw Environment Configuration ────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Required ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here

# ── Project Configuration ───────────────────────────────────────────────────
# Path to the project the agent manages (where tasks get implemented)
PROJECT_DIR=C:\HomeAssistant

# Path to tasks.json and ideas.json (default: data/ inside agent dir)
# TASKS_FILE=data\tasks.json
# IDEAS_FILE=data\ideas.json

# ── Agent Behavior ──────────────────────────────────────────────────────────
# Poll interval in seconds (default: 3600 = 1 hour)
# AGENT_POLL_INTERVAL=3600

# Daily GPT-4o API call cap (default: 10)
# AGENT_MAX_CALLS=10

# HTTP trigger port (default: 8099)
# AGENT_TRIGGER_PORT=8099

# ── CLI Provider Configuration ──────────────────────────────────────────────
# Default provider for all operations (must match a key in providers.json)
# CLI_PROVIDER=copilot

# Override provider per-phase (optional — falls back to CLI_PROVIDER)
# CLI_PLAN_PROVIDER=copilot
# CLI_IMPLEMENT_PROVIDER=claude
# CLI_SECURITY_PROVIDER=copilot

# ── Provider-Specific API Keys ──────────────────────────────────────────────
# (Only needed if using that provider)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# ── Timeouts (override providers.json defaults) ────────────────────────────
# COPILOT_TIMEOUT=600
# COPILOT_PLAN_TIMEOUT=900
# COPILOT_SECURITY_TIMEOUT=300

# ── GPT-4o API Planning Backend ─────────────────────────────────────────────
# GitHub Models endpoint for GPT-4o planning (not CLI-based)
# GITHUB_MODELS_URL=https://models.inference.ai.azure.com/chat/completions
# GITHUB_MODELS_MODEL=gpt-4o

# ── Pipeline / Program Manager ───────────────────────────────────────────────
# PIPELINE_FILE=pipeline.json
# PIPELINE_PM_URL=http://localhost:11434/v1/chat/completions  # for local model
# PIPELINE_PM_KEY=                                            # for local model
# PIPELINE_REWRITE_TIMEOUT=120
# PIPELINE_PLAN_TIMEOUT=900
# PIPELINE_CODE_TIMEOUT=600
# PIPELINE_TEST_TIMEOUT=300
# PIPELINE_REVIEW_TIMEOUT=300
# PIPELINE_MANAGER_TIMEOUT=300

# ── Home Assistant (optional) ───────────────────────────────────────────────
# HA_URL=http://localhost:8123
# HA_TOKEN=your_long_lived_access_token
